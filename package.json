{
  "name": "serverless-indexer",
  "version": "1.0.0",
  "description": "",
  "main": "handler.js",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "predo-deploy": "dotenv -e .env.prd -- sh -c 'doctl serverless connect prd-search-indexer --access-key $ACCESS_KEY_ID:$ACCESS_KEY_SECRET'",
    "do-deploy": "dotenv -e .env.prd -- doctl serverless deploy '../search-indexer'",
    "predo-deploy-dev": "dotenv -e .env.dev -- sh -c 'doctl serverless connect dev-search-indexer --access-key $ACCESS_KEY_ID:$ACCESS_KEY_SECRET'",
    "do-deploy-dev": "dotenv -e .env.dev -- doctl serverless deploy '../search-indexer'",
    "do-list-namespaces": "doctl serverless namespaces list",
    "format": "prettier --ignore-path .gitignore --write .",
    "lint": "npm-run-all lint:*",
    "lint:code": "eslint . --cache",
    "lint:pretty": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "algoliasearch": "5.55.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "dotenv-cli": "11.0.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.5"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "license": "BSD-3-Clause"
}
